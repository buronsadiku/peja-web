# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001

# Database — Better Auth talks to Postgres directly. Same instance the
# NestJS API uses (docker compose up brings it up on 5432).
DATABASE_URL=postgresql://peja:peja@localhost:5432/peja

# Auth — two independent secrets. AUTH_COOKIE_SECRET MUST match the
# value in peja-api/.env so the API can verify the cookie HMAC.
# Generate with: openssl rand -base64 48
AUTH_COOKIE_SECRET=replace-me-with-32-plus-random-bytes-aaaaaaaaaaaaaaaa
AUTH_HASH_PEPPER=replace-me-with-32-plus-random-bytes-bbbbbbbbbbbbbbbb

# Cookie domain — leave unset for localhost. Set to ".peja.app" in prod
# so api.peja.app and app.peja.app share the session cookie.
COOKIE_DOMAIN=

# Trusted origins for Better Auth CSRF + redirect checks (CSV).
TRUSTED_ORIGINS=http://localhost:3000

# OAuth (leave empty in dev unless you've registered local apps)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# Email — Better Auth uses this for verification + password reset
RESEND_API_KEY=
EMAIL_FROM=Peja <hello@peja.app>

# Error tracking
SENTRY_DSN=
